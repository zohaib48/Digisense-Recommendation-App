# Shopify App Configuration
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_HOST=your-tunnel-url.trycloudflare.com
FRONTEND_URL=https://your-tunnel-url.trycloudflare.com
VITE_SHOPIFY_API_KEY=your_api_key_here
SCOPES=read_products,write_products,read_content,write_content

# Server Configuration
PORT=3000
NODE_ENV=development

# Recommendation Settings
PRICE_RANGE_PERCENTAGE=20
MAX_RECOMMENDATIONS=8
CACHE_TTL=300
