{
  "name": "shopify-recommendations-app",
  "version": "1.0.0",
  "description": "Smart product recommendations based on size and price",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "setup": "node setup.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --watch server --ext js,json --signal SIGTERM server/index.js",
    "dev:client": "vite",
    "start": "node server/index.js",
    "launch": "node launch.js",
    "db:migrate": "node server/db/migrate.js",
    "build": "vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "shopify",
    "recommendations",
    "app"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@shopify/app-bridge": "^3.7.10",
    "@shopify/app-bridge-react": "^3.7.10",
    "@shopify/polaris": "^12.0.0",
    "@shopify/shopify-api": "^9.0.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "node-cache": "^5.1.2",
    "pg": "^8.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "localtunnel": "^2.0.2",
    "nodemon": "^3.1.11",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}